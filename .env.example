# ─────────────────────────────────────────────────────────────
# SoftLaunch — Required Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real secrets.
# ─────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────
# DATABASE (Supabase — transaction pooler)
#
# Use the TRANSACTION POOLER URL (port 6543), NOT the direct connection.
# The transaction pooler works on all networks (residential ISPs block 5432).
#
# How to get this URL:
#   Supabase Dashboard → Your project → Settings → Database
#   → Connection string → Transaction pooler
#   Copy the full string — it pre-encodes your password.
#
# The URL format is:
#   postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
#
# IMPORTANT: sslmode=require is mandatory for Netlify/cloud deployments.
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# ─────────────────────────────────────────────────────────────
# AUTHENTICATION (Clerk)
# https://dashboard.clerk.com → Your app → API Keys
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk redirect URLs (do not change unless you rename routes)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding/welcome
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# ─────────────────────────────────────────────────────────────
# PAYMENTS (Stripe)
# https://dashboard.stripe.com → Developers → API keys
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_30=price_...

# ─────────────────────────────────────────────────────────────
# EMAIL (Resend)
# https://resend.com → API Keys
#
# FROM_EMAIL:
#   Dev:  onboarding@resend.dev  (Resend shared test sender — no domain needed)
#   Prod: Founders@softlaunchhq.com  (only after domain verified at resend.com/domains)
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=onboarding@resend.dev
FOUNDER_EMAIL=founders@softlaunchhq.com

# ─────────────────────────────────────────────────────────────
# OPENAI (BUZZ AI companion)
# https://platform.openai.com → API Keys
# Use gpt-4o-mini on Tier 1 accounts (500 RPM). gpt-4o = 3 RPM on Tier 1.
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────────
# SUPABASE (client-side JS client)
# Supabase Dashboard → Your project → Settings → API
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ─────────────────────────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://softlaunchhq.com
NEXT_PUBLIC_APP_NAME=SoftLaunch

# Admin email addresses — comma-separated, no spaces around commas
ADMIN_EMAILS=founders@softlaunchhq.com

# ─────────────────────────────────────────────────────────────
# OPTIONAL (future)
# ─────────────────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
