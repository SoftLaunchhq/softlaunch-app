# SoftLaunch Environment Variables
# Copy this file to .env.local and fill in your values

# ─────────────────────────────────────────────────────────────
# DATABASE (Supabase — direct connection, no pooler)
# Use the direct host (db.PROJECT.supabase.co:5432), NOT the pooler.
# The pooler uses @neondatabase/serverless internally which breaks Prisma.
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres?sslmode=require"

# ─────────────────────────────────────────────────────────────
# AUTHENTICATION (Clerk)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding/welcome
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# ─────────────────────────────────────────────────────────────
# PAYMENTS (Stripe)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_30=price_...

# ─────────────────────────────────────────────────────────────
# EMAIL (Resend)
# https://resend.com — create a free account, get your API key
#
# FROM_EMAIL:
#   In development: use "onboarding@resend.dev" (Resend's shared test sender).
#   In production:  use "Founders@softlaunchhq.com" — BUT only after verifying
#                   the domain softlaunchhq.com at https://resend.com/domains.
#                   Resend will NOT send from a custom address until the domain
#                   is verified. Emails will silently fail or be rejected.
#
# FOUNDER_EMAIL:
#   The internal address that receives a notification on every new waitlist signup.
#   Set this to your real founder inbox.
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=Founders@softlaunchhq.com
FOUNDER_EMAIL=Founders@softlaunchhq.com

# ─────────────────────────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SoftLaunch

# Admin email addresses (comma-separated, for role detection)
ADMIN_EMAILS=founders@softlaunchhq.com

# ─────────────────────────────────────────────────────────────
# OPENAI (BUZZ AI companion — required for AI features)
# IMPORTANT: Use gpt-4o-mini on Tier 1 accounts ($5–$50 balance)
#   gpt-4o-mini = 500 RPM  ← use this
#   gpt-4o      = 3 RPM    ← causes constant 429s on low-tier accounts
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────────
# SUPABASE (client-side)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_ID].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# ─────────────────────────────────────────────────────────────
# OPTIONAL
# ─────────────────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
